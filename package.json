{
	"name": "deepink",
	"productName": "Deepink",
	"description": "Privacy focused notes",
	"author": "Robert Vitonsky",
	"version": "0.0.2-preview.8",
	"main": "dist/main.js",
	"homepage": "https://github.com/vitonsky/deepink",
	"bugs": {
		"url": "https://github.com/vitonsky/deepink/issues"
	},
	"license": " AGPL-3.0",
	"engines": {
		"node": ">=22"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"onFail": "error"
		},
		"packageManager": {
			"name": "npm",
			"onFail": "error"
		}
	},
	"scripts": {
		"test": "vitest",
		"bench": "node scripts/datasets/prepare-bench-data.ts  && vitest bench",
		"prettify": "eslint --fix \"{*,**/*}.{ts,tsx,js,jsx}\" && prettier --write \"{*,**/*}.{ts,tsx,js,jsx}\" && stylelint '**/*.css' --fix",
		"lint": "eslint --max-warnings 0 \"{*,**/*}.{ts,tsx,js,jsx}\" && prettier --check \"{*,**/*}.{ts,tsx,js,jsx}\" && stylelint '**/*.css'",
		"update-icons": "tsx ./scripts/icons/build.ts",
		"prepare": "husky install"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.3.1",
		"@commitlint/config-conventional": "^20.3.1",
		"@cspell/eslint-plugin": "^9.6.2",
		"@octokit/rest": "^22.0.1",
		"@reforged/maker-appimage": "^5.1.1",
		"@swc/core": "^1.15.11",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/file-saver": "^2.0.7",
		"@types/humanize-duration": "^3.27.4",
		"@types/lodash": "^4.17.23",
		"@types/mime-types": "^3.0.1",
		"@types/node": "^25.0.10",
		"@types/react": "^19.2.10",
		"@types/react-dom": "^19.2.3",
		"@types/recursive-readdir": "^2.2.4",
		"@types/semver": "^7.7.1",
		"@types/sql.js": "^1.4.10",
		"@types/unbzip2-stream": "^1.4.3",
		"@types/uuid": "^11.0.0",
		"@vitest/web-worker": "^4.1.1",
		"blob-polyfill": "^9.0.20240710",
		"cross-env": "^10.1.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-paths": "^1.1.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-unused-imports": "^4.3.0",
		"husky": "^9.1.7",
		"jsdom": "^27.4.0",
		"lint-staged": "^16.2.7",
		"memfs": "^4.56.10",
		"mime-types": "^3.0.2",
		"mini-css-extract-plugin": "^2.10.0",
		"npm-check-updates": "^19.3.2",
		"p-limit": "^7.2.0",
		"patch-package": "^8.0.1",
		"prettier": "^3.8.1",
		"sax": "^1.6.0",
		"sharp": "^0.34.5",
		"sharp-ico": "^0.1.5",
		"stylelint": "^17.0.0",
		"stylelint-config-standard": "^40.0.0",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"unbzip2-stream": "^1.4.3",
		"vite-tsconfig-paths": "^6.0.5",
		"vitest": "^4.1.1"
	},
	"workspaces": ["packages/*"]
}
