---
import Document, { type Props as DocumentProps } from '../components/Document.astro';
import MarkdownContent from '../components/MarkdownContent.astro';
import { StaticPage } from '../features/StaticPage';

import { i18nGetContext } from '../i18n/utils';

interface Props extends Pick<DocumentProps, 'meta'> {}

const { meta } = Astro.props;

const i18n = i18nGetContext({
	language: 'en',
	namespaces: [],
});
---

<Document lang={i18n.language} meta={{ alts: i18n.altVersions, ...meta }}>
	<StaticPage i18n={i18n} client:load>
		<MarkdownContent>
			<slot />
		</MarkdownContent>
	</StaticPage>
</Document>
