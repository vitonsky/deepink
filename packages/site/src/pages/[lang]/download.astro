---
import Document from '../../components/Document.astro';
import Page from '../../features/Download';
import { getReleases } from '../../features/releases';

import { getStaticLangPaths, i18nGetContext } from '../../i18n/utils';

const { lang } = Astro.params;
const i18n = i18nGetContext({
	language: lang,
	// TODO: localize page
	namespaces: [],
	path: Astro.url.pathname,
});

export function getStaticPaths() {
	return getStaticLangPaths();
}

const releases = await getReleases(import.meta.env.GITHUB_TOKEN);
---

<Document lang={i18n.language} meta={{ alts: i18n.altVersions }}>
	<Page client:load versions={releases} i18n={i18n} />
</Document>
