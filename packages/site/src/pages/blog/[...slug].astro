---
import Document from '../../components/Document.astro';
import { BlogPost } from '../../features/Blog/BlogPost';

import { i18nGetContext } from '../../i18n/utils';

import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await post.render();

const i18n = i18nGetContext({
	language: 'en',
	namespaces: [],
});
---

<Document lang={i18n.language} meta={{ alts: i18n.altVersions }}>
	<BlogPost
		client:load
		i18n={i18n}
		meta={{ slug: post.slug, data: post.data }}
		url={Astro.url.toString()}
	>
		<div class="sl-markdown-content no-css-reset">
			<Content />
		</div>
	</BlogPost>
</Document>

<style>
	:global(.sl-markdown-content) {
		line-height: 1.7;
		
		* + :is(h1, h2, h3) {
			margin-top: 3rem;
		}

		ul {
			padding-inline-start: 1rem;
		}

		ul > ul {
			padding-inline-start: 3rem;
		}

		li:has(li) {
			margin-bottom: 1rem;
			& & {
				margin-bottom: 0.3rem;
				& & {
					margin-bottom: 0;
				}
			}
		}

		li:last-child {
			margin-bottom: 0;
		}

		img {
			height: auto;
			max-width: 100%;
			border: 1px solid #00000017;
			border-radius: 8px;
		}

		pre[data-language] {
			border: 1px solid peachpuff;
			border-radius: 8px;
		}

		blockquote {
			background: #ffdab93d;
			margin: 0;
			padding: 0.8rem 1.5rem;
			border-radius: 12px;
		}

		--ec-frm-inlBtnFg: var(--chakra-colors-brand-secondary);
		--ec-frm-inlBtnBrd: var(--chakra-colors-border-thin);
	}
</style>
