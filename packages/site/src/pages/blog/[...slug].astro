---
import Document from '../../components/Document.astro';
import { BlogPost } from '../../features/Blog/BlogPost';

import { i18nGetContext } from '../../i18n/utils';

import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await post.render();

const i18n = i18nGetContext({
	language: 'en',
	namespaces: [],
});
---

<Document lang={i18n.language} meta={{ alts: i18n.altVersions }}>
	<BlogPost
		client:load
		i18n={i18n}
		meta={{ slug: post.slug, data: post.data }}
		url={Astro.url.toString()}
	>
		<div class="sl-markdown-content no-css-reset">
			<Content />
		</div>
	</BlogPost>
</Document>

<style>
	:global(.sl-markdown-content) {
		img {
			height: auto;
			max-width: 100%;
		}

		pre[data-language] {
			border: 1px solid peachpuff;
			border-radius: 8px;
		}

		--ec-frm-inlBtnFg: var(--chakra-colors-brand-secondary);
		--ec-frm-inlBtnBrd: var(--chakra-colors-border-thin);
	}
</style>
