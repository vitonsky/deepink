---
import Document from '../components/Document.astro';
import MarkdownContent from '../components/MarkdownContent.astro';
import { StaticPage } from '../features/StaticPage';

import { i18nGetContext } from '../i18n/utils';

import Page from '../content/legal/privacy.md';

const i18n = i18nGetContext({
	language: 'en',
	namespaces: [],
});
---

<Document lang={i18n.language} meta={{ alts: i18n.altVersions }}>
	<StaticPage i18n={i18n} client:load>
		<MarkdownContent>
			<Page />
		</MarkdownContent>
	</StaticPage>
</Document>
